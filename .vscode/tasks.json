{
  "version": "2.0.0",
  "tasks": [
    {
      // The dev-shell environment (cargo, WEBPGF_PATH, …) comes from direnv
      // (.envrc + the mkhl.direnv extension); .envrc exports CARGO as an
      // absolute path so rust-analyzer's cargo task type finds the binary.
      // Run with the default build shortcut (Ctrl/Cmd+Shift+B).
      "label": "cargo build --release",
      "type": "cargo",
      "command": "build",
      "args": ["--release"],
      "problemMatcher": ["$rustc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
